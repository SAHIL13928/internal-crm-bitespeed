# Copy to .env and fill in real values. .env is gitignored.
#
# On the EC2 box:
#   cp .env.example .env
#   nano .env       # paste your secrets
#   docker compose up -d

# ── Postgres (lives in the docker-compose stack on the same box) ─────────
# DATABASE_URL is auto-built by docker-compose from the three vars below
# and injected into the app container — you don't set it here.
# The DB password is the only thing here that matters operationally —
# pick something long. Username + db name can stay default unless you
# need otherwise.
POSTGRES_DB=cs_crm
POSTGRES_USER=cs_crm
POSTGRES_PASSWORD=replace-with-long-random-string

# ── Dashboard / read-API basic auth ──────────────────────────────────────
# Generate a strong password:
#     python -c "import secrets; print(secrets.token_urlsafe(24))"
API_USERNAME=bitespeed
API_PASSWORD=replace-with-long-random-string

# Comma-separated list, no trailing slashes. For the EC2 demo, set this
# to the public URL nginx serves (e.g. http://ec2-…amazonaws.com).
# Leave unset for a wide-open dev box (a warning will be logged at boot).
ALLOWED_ORIGINS=http://ec2-34-239-140-115.compute-1.amazonaws.com

# ── Webhook secrets ──────────────────────────────────────────────────────
# Match these to whatever's configured on the provider consoles.
# Leave blank in dev — webhook endpoints will reject signed requests
# but the app starts fine.
WHATSAPP_WEBHOOK_SECRET=
PERISKOPE_SIGNING_SECRET=
FREJUN_WEBHOOK_SECRET=

# ── Admin guard for /admin/conflicts ─────────────────────────────────────
# Also doubles as the SessionMiddleware signing key (used by the Google
# OAuth state cookie). Generate with the same secrets.token_urlsafe call.
ADMIN_SECRET=

# ── Backfill scripts (optional — only needed if you run them manually) ──
PERISKOPE_API_KEY=
PERISKOPE_PHONE=
FREJUN_API_KEY=

# ── Google Calendar integration (optional) ──────────────────────────────
# Only required if you turn on the Calendar sync feature. App boots
# fine without these; calendar endpoints just 503 until configured.
#
# CALENDAR_TOKEN_ENCRYPTION_KEY: Fernet key used to encrypt refresh
# tokens before persisting. Generate with:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_WORKSPACE_DOMAIN=
CALENDAR_TOKEN_ENCRYPTION_KEY=
